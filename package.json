{
  "name": "streamfusion",
  "version": "1.26.0",
  "description": "Unified multi-platform stream chat viewer for Twitch, YouTube, TikTok, and Kick. Built by aquiloGG.",
  "main": "main.js",
  "author": {
    "name": "aquiloGG",
    "email": "bisherclay@gmail.com",
    "url": "https://aquilo.gg"
  },
  "homepage": "https://aquilo.gg",
  "repository": {
    "type": "git",
    "url": "https://github.com/aquiloplays/StreamFusion.git"
  },
  "scripts": {
    "gen-icon": "node scripts/gen-icon.js",
    "prebuild": "node scripts/gen-icon.js",
    "start": "electron .",
    "build": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win --publish never",
    "build:portable": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win portable --publish never",
    "release": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "pngjs": "^7.0.0"
  },
  "build": {
    "appId": "gg.aquilo.streamfusion",
    "productName": "StreamFusion",
    "copyright": "Copyright © 2025 aquiloGG · https://aquilo.gg",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!patreon-proxy.worker.js",
      "!SETUP-PATREON.md",
      "!.env*",
      "!bot-service/**",
      "!sf-obs/**",
      "!preview-icon.js",
      "!icon-preview.png",
      "!release-worker/**",
      "!favorites-worker/**",
      "!dist-beta/**",
      "!scripts/sbae-decoded.json",
      "!scripts/sf-rf-import-new.txt",
      "!scripts/sf-si-import.txt",
      "!scripts/release-notes-*.md",
      "!scripts/HANDOFF.md",
      "!.claude/**",
      "!.github/**",
      "!marketing/**",
      "!wrangler.toml",
      "!.wrangler/**",
      "!_vcwt/**"
    ],
    "asarUnpack": [],
    "publish": [
      {
        "provider": "github",
        "owner": "aquiloplays",
        "repo": "streamfusion-downloads"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": [
        "sha256"
      ],
      "sign": null,
      "publisherName": "aquiloGG",
      "verifyUpdateCodeSignature": false,
      "legalTrademarks": "StreamFusion is a trademark of aquiloGG."
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.entertainment"
    },
    "nsis": {
      "artifactName": "StreamFusion-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StreamFusion",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true
    },
    "portable": {
      "artifactName": "StreamFusion-Portable-${version}.exe"
    }
  }
}
